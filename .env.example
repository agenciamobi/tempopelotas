NEXT_PUBLIC_SITE_URL=http://localhost:5175

# Aplicativo PWA e notificações web push.
# Gere as chaves uma única vez com: npm run pwa:keys
NEXT_PUBLIC_VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:contato@agenciamobi.com.br
PUSH_ADMIN_SECRET=

# Resumos automáticos da previsão para hoje e amanhã.
# A chave permanece somente no servidor. GOOGLE_API_KEY tem precedência quando ambas existirem.
# Configure a variável também no ambiente Production da Vercel antes do deployment.
GEMINI_API_KEY=
# GOOGLE_API_KEY=
GEMINI_MODEL=gemini-3.5-flash

# Login com Google via Supabase Auth.
# Use a URL e a publishable key exibidas em Supabase > Connect.
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=
# Compatibilidade temporária com a chave anon legada.
# NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_URL=
SUPABASE_PUBLISHABLE_KEY=
# SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Transmissão ativa ou gravação mais recente da Praia do Laranjal.
YOUTUBE_API_KEY=
YOUTUBE_CHANNEL_HANDLE=@praiadolaranjal

# APIs Google disponíveis para integrações aprovadas no portal.
NEXT_PUBLIC_GOOGLE_MAPS_API_KEY=
NEXT_PUBLIC_GOOGLE_MAPS_EMBED_KEY=
GOOGLE_MAPS_SERVER_API_KEY=
GOOGLE_PAGESPEED_API_KEY=
GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=

# Radar animado de precipitação. A chave fica somente no servidor.
# Requer acesso ao produto OpenWeather Global Precipitation Map Forecast.
OPENWEATHER_API_KEY=

# Windy Stations Open Data.
# Uso atual: diagnóstico local da cobertura de estações, sem publicação no site.
WINDY_STATIONS_API_KEY=
WINDY_STATIONS_DIAGNOSTIC_RADIUS_KM=150
WINDY_STATIONS_DIAGNOSTIC_OBSERVATION_LIMIT=20

# Arquivo meteorológico e inscrições push em Supabase.
CRON_SECRET=

# Opcionais: transmissões externas. URLs configuradas aqui têm precedência sobre o YouTube.
CAMERA_LARANJAL_EMBED_URL=
CAMERA_LARANJAL_PUBLIC_URL=
CAMERA_LARANJAL_PROVIDER=

CAMERA_CENTRO_EMBED_URL=
CAMERA_CENTRO_PUBLIC_URL=
CAMERA_CENTRO_PROVIDER=

CAMERA_SAO_GONCALO_EMBED_URL=
CAMERA_SAO_GONCALO_PUBLIC_URL=
CAMERA_SAO_GONCALO_PROVIDER=
