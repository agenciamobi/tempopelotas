NEXT_PUBLIC_SITE_URL=http://localhost:5175

# Aplicativo PWA e notificações web push.
# Gere as chaves uma única vez com: npm run pwa:keys
NEXT_PUBLIC_VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:contato@agenciamobi.com.br
PUSH_ADMIN_SECRET=

# Resumos automáticos da previsão para hoje e amanhã.
# A chave permanece somente no servidor. O modelo é opcional.
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash

# Radar animado de precipitação. A chave fica somente no servidor.
# Requer acesso ao produto OpenWeather Global Precipitation Map Forecast.
OPENWEATHER_API_KEY=

# Windy Stations Open Data.
# Uso atual: diagnóstico local da cobertura de estações, sem publicação no site.
# Gere a chave em https://stations.windy.com/keys e mantenha somente no servidor.
WINDY_STATIONS_API_KEY=
WINDY_STATIONS_DIAGNOSTIC_RADIUS_KM=150
WINDY_STATIONS_DIAGNOSTIC_OBSERVATION_LIMIT=20

# Arquivo meteorológico e inscrições push em Supabase.
# Nunca exponha a service role no navegador.
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=
CRON_SECRET=

# Opcionais: transmissões externas. Use URLs de incorporação HTTPS fornecidas pelo provedor.
CAMERA_LARANJAL_EMBED_URL=
CAMERA_LARANJAL_PUBLIC_URL=
CAMERA_LARANJAL_PROVIDER=

CAMERA_CENTRO_EMBED_URL=
CAMERA_CENTRO_PUBLIC_URL=
CAMERA_CENTRO_PROVIDER=

CAMERA_SAO_GONCALO_EMBED_URL=
CAMERA_SAO_GONCALO_PUBLIC_URL=
CAMERA_SAO_GONCALO_PROVIDER=
